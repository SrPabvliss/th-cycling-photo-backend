generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMs ──────────────────────────────────────────────────────────────────

enum EventStatus {
  active
  archived

  @@map("event_status")
}

enum PhotoStatus {
  pending
  detecting
  analyzing
  completed
  failed

  @@map("photo_status")
}

enum UnclassifiedReason {
  no_cyclist
  ocr_failed
  low_confidence
  processing_error

  @@map("unclassified_reason")
}

enum JobStatus {
  pending
  processing
  completed
  failed

  @@map("job_status")
}

enum JobType {
  detection
  ocr
  color_analysis

  @@map("job_type")
}

enum ProcessingStage {
  detection
  ocr
  color_analysis
  completed

  @@map("processing_stage")
}

enum ClassificationSource {
  manual
  ai

  @@map("classification_source")
}

enum RoleType {
  admin
  classifier

  @@map("role_type")
}

enum EquipmentItem {
  helmet
  clothing
  bike

  @@map("equipment_item")
}

enum PreviewLinkStatus {
  active
  expired
  converted

  @@map("preview_link_status")
}

enum OrderStatus {
  pending
  paid
  delivered
  cancelled

  @@map("order_status")
}

enum DeliveryLinkStatus {
  active
  expired
  downloaded

  @@map("delivery_link_status")
}

enum EventAssetType {
  cover_image
  event_logo
  hero_image
  poster

  @@map("event_asset_type")
}

enum RiderCategory {
  pre_infantil
  infantil
  pre_juvenil
  juvenil
  damas_abiertas
  damas_elite
  novatos_dobles
  novatos_rigidos
  master_a
  master_b
  master_c
  e_bike
  enduro_a
  enduro_b
  rigidas
  elite
  pro_elite

  @@map("rider_category")
}

// ─── Reference Tables ───────────────────────────────────────────────────────

model Province {
  id         Int    @id @default(autoincrement())
  name       String @db.VarChar(100)
  code       String @unique @db.VarChar(10)
  country_id Int?

  country   Country?   @relation(fields: [country_id], references: [id], onDelete: Restrict)
  cantons   Canton[]
  events    Event[]
  customers Customer[]

  @@index([country_id])
  @@map("provinces")
}

model Canton {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(100)
  province_id Int

  province  Province   @relation(fields: [province_id], references: [id])
  events    Event[]
  customers Customer[]

  @@index([province_id])
  @@map("cantons")
}

model Country {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(100)
  iso_code String @unique @db.VarChar(2)

  provinces Province[]
  customers Customer[]

  @@map("countries")
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  first_name    String?   @db.VarChar(100)
  last_name     String?   @db.VarChar(100)
  phone         String?   @db.VarChar(20)
  avatar_url         String?   @db.VarChar(500)
  avatar_storage_key String?   @db.VarChar(500)
  is_active          Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamptz
  last_login_at DateTime? @db.Timestamptz

  user_roles     UserRole[]
  refresh_tokens RefreshToken[]

  events_created            Event[]           @relation("EventCreatedBy")
  events_updated            Event[]           @relation("EventUpdatedBy")
  photos_created            Photo[]           @relation("PhotoCreatedBy")
  photos_updated            Photo[]           @relation("PhotoUpdatedBy")
  cyclists_created          DetectedCyclist[] @relation("CyclistCreatedBy")
  cyclists_classified       DetectedCyclist[] @relation("CyclistClassifiedBy")
  plates_corrected          PlateNumber[]     @relation("PlateNumberCorrectedBy")
  preview_links_created     PreviewLink[]     @relation("PreviewLinkCreatedBy")
  orders_confirmed          Order[]           @relation("OrderConfirmedBy")
  notifications             Notification[]

  @@map("users")
}

model Role {
  id         String   @id @default(uuid()) @db.Uuid
  name       RoleType @unique
  created_at DateTime @default(now()) @db.Timestamptz

  user_roles UserRole[]

  @@map("roles")
}

model UserRole {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  role_id     String   @db.Uuid
  assigned_at DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  token_hash String    @unique
  user_id    String    @db.Uuid
  expires_at DateTime  @db.Timestamptz
  revoked_at DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("refresh_tokens")
}

model Event {
  id               String      @id @default(uuid()) @db.Uuid
  name             String      @db.VarChar(200)
  description      String?     @db.Text
  event_date       DateTime    @db.Date
  location         String?     @db.VarChar(200)
  province_id      Int?
  canton_id        Int?
  cover_image_url         String?     @db.VarChar(500)
  cover_image_storage_key String?     @db.VarChar(500)
  is_featured             Boolean     @default(false)
  status                  EventStatus @default(active)
  created_at              DateTime    @default(now()) @db.Timestamptz
  updated_at       DateTime    @default(now()) @updatedAt @db.Timestamptz
  deleted_at       DateTime?   @db.Timestamptz

  created_by_id String? @db.Uuid
  updated_by_id String? @db.Uuid

  province   Province? @relation(fields: [province_id], references: [id])
  canton     Canton?   @relation(fields: [canton_id], references: [id])
  created_by User?     @relation("EventCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  updated_by User?     @relation("EventUpdatedBy", fields: [updated_by_id], references: [id], onDelete: SetNull)
  photos           Photo[]
  preview_links    PreviewLink[]
  orders           Order[]
  assets           EventAsset[]
  photo_categories EventPhotoCategory[]

  @@index([status])
  @@index([event_date(sort: Desc)])
  @@index([deleted_at])
  @@index([province_id])
  @@index([canton_id])
  @@index([created_by_id])
  @@map("events")
}

model Photo {
  id       String @id @default(uuid()) @db.Uuid
  event_id String @db.Uuid

  filename    String @db.VarChar(255)
  storage_key String @unique @db.VarChar(500)
  file_size   BigInt
  mime_type   String @default("image/jpeg") @db.VarChar(50)
  width       Int?
  height      Int?

  status              PhotoStatus         @default(pending)
  unclassified_reason UnclassifiedReason?

  retouched_storage_key String?  @unique @db.VarChar(500)
  retouched_file_size   BigInt?
  retouched_at          DateTime? @db.Timestamptz

  captured_at   DateTime? @db.Timestamptz
  uploaded_at   DateTime  @default(now()) @db.Timestamptz
  processed_at  DateTime? @db.Timestamptz
  classified_at DateTime? @db.Timestamptz

  embedding Unsupported("vector(1024)")?

  created_by_id     String? @db.Uuid
  updated_by_id     String? @db.Uuid
  photo_category_id String? @db.Uuid

  event             Event              @relation(fields: [event_id], references: [id], onDelete: Cascade)
  created_by        User?              @relation("PhotoCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  updated_by        User?              @relation("PhotoUpdatedBy", fields: [updated_by_id], references: [id], onDelete: SetNull)
  photo_category    EventPhotoCategory? @relation(fields: [photo_category_id], references: [id], onDelete: SetNull)
  detected_cyclists   DetectedCyclist[]
  processing_jobs     ProcessingJob[]
  preview_link_photos PreviewLinkPhoto[]
  order_photos        OrderPhoto[]

  @@index([event_id, filename])
  @@index([event_id])
  @@index([status])
  @@index([event_id, unclassified_reason], map: "idx_photos_unclassified")
  @@index([created_by_id])
  @@index([photo_category_id])
  // HNSW index for cosine similarity is created via raw SQL in the migration
  @@map("photos")
}

model DetectedCyclist {
  id       String @id @default(uuid()) @db.Uuid
  photo_id String @db.Uuid

  source ClassificationSource @default(manual)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  created_by_id   String? @db.Uuid
  classified_by_id String? @db.Uuid

  photo            Photo              @relation(fields: [photo_id], references: [id], onDelete: Cascade)
  created_by       User?              @relation("CyclistCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  classified_by    User?              @relation("CyclistClassifiedBy", fields: [classified_by_id], references: [id], onDelete: SetNull)
  plate_number     PlateNumber?
  equipment_colors EquipmentColor[]
  ai_metadata      CyclistAiMetadata?

  @@index([photo_id])
  @@index([created_by_id])
  @@map("detected_cyclists")
}

model CyclistAiMetadata {
  id                  String @id @default(uuid()) @db.Uuid
  detected_cyclist_id String @unique @db.Uuid

  bounding_box         Json    @db.JsonB
  detection_confidence Decimal @db.Decimal(5, 4)

  created_at DateTime @default(now()) @db.Timestamptz

  detected_cyclist DetectedCyclist @relation(fields: [detected_cyclist_id], references: [id], onDelete: Cascade)

  @@index([detected_cyclist_id])
  @@map("cyclist_ai_metadata")
}

model PlateNumber {
  id                  String @id @default(uuid()) @db.Uuid
  detected_cyclist_id String @unique @db.Uuid

  number           Int
  confidence_score Decimal? @db.Decimal(5, 4)

  manually_corrected Boolean   @default(false)
  corrected_at       DateTime? @db.Timestamptz
  corrected_by_id    String?   @db.Uuid

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  detected_cyclist DetectedCyclist @relation(fields: [detected_cyclist_id], references: [id], onDelete: Cascade)
  corrected_by     User?           @relation("PlateNumberCorrectedBy", fields: [corrected_by_id], references: [id], onDelete: SetNull)

  @@index([number])
  @@index([detected_cyclist_id])
  @@map("plate_numbers")
}

model EquipmentColor {
  id                  String @id @default(uuid()) @db.Uuid
  detected_cyclist_id String @db.Uuid

  item_type          EquipmentItem @map("item_type")
  color_name         String        @db.VarChar(50)
  color_hex          String        @db.VarChar(7)
  raw_hex            String?       @db.VarChar(7)
  density_percentage Decimal?      @db.Decimal(5, 2)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  detected_cyclist DetectedCyclist @relation(fields: [detected_cyclist_id], references: [id], onDelete: Cascade)

  @@index([detected_cyclist_id])
  @@index([item_type])
  @@index([color_name])
  @@map("equipment_colors")
}

model ProcessingJob {
  id       String @id @default(uuid()) @db.Uuid
  photo_id String @db.Uuid

  job_type         JobType         @map("job_type")
  status           JobStatus       @default(pending)
  processing_stage ProcessingStage @map("processing_stage")

  error_message String? @db.Text
  retry_count   Int     @default(0)
  max_retries   Int     @default(3)

  started_at   DateTime? @db.Timestamptz
  completed_at DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz

  photo Photo @relation(fields: [photo_id], references: [id], onDelete: Cascade)

  @@index([photo_id])
  @@index([status])
  @@index([job_type])
  @@map("processing_jobs")
}

// ─── Commercial Flow ────────────────────────────────────────────────────────

model Customer {
  id              String         @id @default(uuid()) @db.Uuid
  first_name      String         @db.VarChar(100)
  last_name       String         @db.VarChar(100)
  whatsapp        String         @unique @db.VarChar(20)
  email           String?        @db.VarChar(255)
  country_id      Int?
  province_id     Int?
  canton_id       Int?
  rider_category  RiderCategory?
  created_at      DateTime       @default(now()) @db.Timestamptz

  country  Country?  @relation(fields: [country_id], references: [id], onDelete: Restrict)
  province Province? @relation(fields: [province_id], references: [id], onDelete: Restrict)
  canton   Canton?   @relation(fields: [canton_id], references: [id], onDelete: Restrict)
  orders   Order[]

  @@index([email])
  @@index([country_id])
  @@index([province_id])
  @@index([canton_id])
  @@map("customers")
}

model PreviewLink {
  id            String            @id @default(uuid()) @db.Uuid
  token         String            @unique @db.VarChar(64)
  event_id      String            @db.Uuid
  status        PreviewLinkStatus @default(active)
  expires_at    DateTime          @db.Timestamptz
  viewed_at     DateTime?         @db.Timestamptz
  created_at    DateTime          @default(now()) @db.Timestamptz
  created_by_id String            @db.Uuid

  event      Event              @relation(fields: [event_id], references: [id], onDelete: Restrict)
  created_by User               @relation("PreviewLinkCreatedBy", fields: [created_by_id], references: [id], onDelete: Restrict)
  photos     PreviewLinkPhoto[]
  orders     Order[]

  @@index([event_id])
  @@index([status])
  @@index([created_by_id])
  @@index([expires_at])
  @@map("preview_links")
}

model PreviewLinkPhoto {
  id              String @id @default(uuid()) @db.Uuid
  preview_link_id String @db.Uuid
  photo_id        String @db.Uuid

  preview_link PreviewLink @relation(fields: [preview_link_id], references: [id], onDelete: Restrict)
  photo        Photo       @relation(fields: [photo_id], references: [id], onDelete: Restrict)

  @@unique([preview_link_id, photo_id])
  @@index([preview_link_id])
  @@index([photo_id])
  @@map("preview_link_photos")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  preview_link_id String      @db.Uuid
  event_id        String      @db.Uuid
  customer_id     String      @db.Uuid
  status          OrderStatus @default(pending)
  bib_number      Int?
  notes           String?     @db.Text
  created_at      DateTime    @default(now()) @db.Timestamptz
  paid_at         DateTime?   @db.Timestamptz
  delivered_at    DateTime?   @db.Timestamptz
  cancelled_at    DateTime?   @db.Timestamptz
  confirmed_by_id String?     @db.Uuid

  preview_link  PreviewLink   @relation(fields: [preview_link_id], references: [id], onDelete: Restrict)
  event         Event         @relation(fields: [event_id], references: [id], onDelete: Restrict)
  customer      Customer      @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  confirmed_by  User?         @relation("OrderConfirmedBy", fields: [confirmed_by_id], references: [id], onDelete: Restrict)
  photos        OrderPhoto[]
  delivery_link DeliveryLink?

  @@index([preview_link_id])
  @@index([event_id])
  @@index([customer_id])
  @@index([status])
  @@index([confirmed_by_id])
  @@index([created_at(sort: Desc)])
  @@map("orders")
}

model OrderPhoto {
  id       String @id @default(uuid()) @db.Uuid
  order_id String @db.Uuid
  photo_id String @db.Uuid

  order Order @relation(fields: [order_id], references: [id], onDelete: Restrict)
  photo Photo @relation(fields: [photo_id], references: [id], onDelete: Restrict)

  @@unique([order_id, photo_id])
  @@index([order_id])
  @@index([photo_id])
  @@map("order_photos")
}

model DeliveryLink {
  id                  String             @id @default(uuid()) @db.Uuid
  order_id            String             @unique @db.Uuid
  token               String             @unique @db.VarChar(64)
  status              DeliveryLinkStatus @default(active)
  expires_at          DateTime           @db.Timestamptz
  first_downloaded_at DateTime?          @db.Timestamptz
  download_count      Int                @default(0)
  created_at          DateTime           @default(now()) @db.Timestamptz

  order Order @relation(fields: [order_id], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([expires_at])
  @@map("delivery_links")
}

// ─── Event Assets & Categories ──────────────────────────────────────────────

model EventAsset {
  id          String         @id @default(uuid()) @db.Uuid
  event_id    String         @db.Uuid
  asset_type  EventAssetType
  storage_key String         @unique @db.VarChar(500)
  file_size   BigInt?
  mime_type   String?        @db.VarChar(50)
  uploaded_at DateTime       @default(now()) @db.Timestamptz

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([event_id, asset_type])
  @@index([event_id])
  @@map("event_assets")
}

model EventPhotoCategory {
  id         String   @id @default(uuid()) @db.Uuid
  event_id   String   @db.Uuid
  name       String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz

  event  Event   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  photos Photo[]

  @@unique([event_id, name])
  @@index([event_id])
  @@map("event_photo_categories")
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  type       String    @db.VarChar(50)
  title      String    @db.VarChar(200)
  message    String    @db.VarChar(500)
  data       Json      @default("{}")
  is_read    Boolean   @default(false)
  read_at    DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read, created_at(sort: Desc)])
  @@index([user_id, created_at(sort: Desc)])
  @@map("notifications")
}
