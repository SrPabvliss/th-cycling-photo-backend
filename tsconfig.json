{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "esnext",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@generated/*": ["src/generated/*"],
      "@event-assets/*": ["src/modules/event-assets/*"],
      "@events/*": ["src/modules/events/*"],
      "@photo-categories/*": ["src/modules/photo-categories/*"],
      "@photos/*": ["src/modules/photos/*"],
      "@classifications/*": ["src/modules/classifications/*"],
      "@locations/*": ["src/modules/locations/*"],
      "@users/*": ["src/modules/users/*"],
      "@customers/*": ["src/modules/customers/*"],
      "@previews/*": ["src/modules/previews/*"],
      "@deliveries/*": ["src/modules/deliveries/*"],
      "@orders/*": ["src/modules/orders/*"],
      "@notifications/*": ["src/modules/notifications/*"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true
  },
  "exclude": []
}
