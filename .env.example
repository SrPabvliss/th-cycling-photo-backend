# App
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5498
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cycling_photo_dev
# DB_SSL_MODE=require  # Uncomment for cloud databases

# Backblaze B2 (scoped key: ttv-backend-upload — read, write, delete)
B2_APPLICATION_KEY_ID=your_scoped_key_id
B2_APPLICATION_KEY=your_scoped_key_secret
B2_BUCKET_ID=your_bucket_id
B2_BUCKET_NAME=your_bucket_name
B2_REGION=your_region

# Cloudflare CDN
CLOUDFLARE_CDN_URL=your_cdn_url

# Cloudflare KV (slug→path mapping for CDN Worker)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id
CLOUDFLARE_API_TOKEN=your_api_token_with_kv_edit
CLOUDFLARE_HMAC_SECRET=your_hmac_secret_for_signed_urls
WATERMARK_BASE_URL=https://your-cdn/photos/watermarked
PREVIEW_BASE_URL=http://localhost:5173/preview
DELIVERY_BASE_URL=http://localhost:5173/delivery

# Voyage AI
VOYAGE_API_KEY=your_voyage_api_key

# Redis
REDIS_HOST=localhost
REDIS_PORT=6394

# Auth
JWT_SECRET=your_jwt_secret_change_me
JWT_ACCESS_EXPIRATION_SECONDS=900
JWT_REFRESH_EXPIRY_DAYS=30
CORS_ORIGIN=http://localhost:5173

# Seed
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=test123
OPERATOR_SEED_EMAIL=operator@example.com
OPERATOR_SEED_PASSWORD=test123
CONSUMER_SEED_EMAIL=consumer@example.com
CONSUMER_SEED_PASSWORD=test123
